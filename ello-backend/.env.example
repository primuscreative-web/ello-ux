PORT=3001
NODE_ENV=development
ELLO_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://127.0.0.1:5173,http://127.0.0.1:5180
ELLO_SESSION_TTL_MS=2592000000

# Current default. Keeps local JSON persistence while the Supabase adapter is wired.
ELLO_STORE_DRIVER=json

# Required when ELLO_STORE_DRIVER=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
